<Window x:Class="IDEF3Editor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IDEF3 Editor"
        Height="760" Width="1200"
        MinHeight="500" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>

        <!-- ══════════ ЦВЕТОВАЯ ПАЛИТРА ══════════ -->
        <!--
            Два базовых цвета: оранжевый и серый.
            Оранжевый : #E8650A (основной), #F07820 (светлый), #C45208 (тёмный)
            Серый      : #2B2D30 (заголовок окна), #3D3F43 (фон панели), #505357 (средний),
                         #6B6E73 (приглушённый), #9B9EA3 (светлый), #EFEFEF (поверхность)
            Опасность  : #B03A2E (тёмно-красно-серый, кнопка «Удалить»)
        -->
        <SolidColorBrush x:Key="ColTitleBg"   Color="#2B2D30"/>
        <SolidColorBrush x:Key="ColToolbarBg" Color="#3D3F43"/>
        <SolidColorBrush x:Key="ColSurface"   Color="#EFEFEF"/>
        <SolidColorBrush x:Key="ColCanvas"    Color="#FAFAFA"/>
        <SolidColorBrush x:Key="ColBorder"    Color="#CACBCC"/>

        <!-- Оранжевый — цвет основных действий -->
        <SolidColorBrush x:Key="ColOrange"    Color="#E8650A"/>
        <SolidColorBrush x:Key="ColOrangeLt"  Color="#F07820"/>
        <SolidColorBrush x:Key="ColOrangeDk"  Color="#C45208"/>

        <!-- Оттенки серого для кнопок -->
        <SolidColorBrush x:Key="ColGrayDk"    Color="#505357"/>  <!-- отмена/повтор, сетка, масштаб -->
        <SolidColorBrush x:Key="ColGrayMid"   Color="#6B6E73"/>  <!-- второстепенные действия -->
        <SolidColorBrush x:Key="ColGrayLt"    Color="#9B9EA3"/>  <!-- неактивные элементы -->

        <!-- Цвет опасного действия (удаление) -->
        <SolidColorBrush x:Key="ColDanger"    Color="#B03A2E"/>

        <!-- Цвет текста строки состояния -->
        <SolidColorBrush x:Key="ColStatus"    Color="#6B6E73"/>

        <!-- ══════════ СТИЛЬ КНОПКИ ПАНЕЛИ ИНСТРУМЕНТОВ ══════════ -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Неактивная кнопка — полупрозрачная -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.30"/>
                            </Trigger>
                            <!-- Наведение курсора — чуть темнее -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.80"/>
                            </Trigger>
                            <!-- Нажатие — смещение на 1px вниз для тактильного ощущения -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.60"/>
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value><TranslateTransform Y="1"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════ КНОПКИ УПРАВЛЕНИЯ ОКНОМ (свернуть / развернуть / закрыть) ══════════ -->
        <Style x:Key="WinCtrlBtn" TargetType="Button">
            <Setter Property="Width"           Value="34"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#9B9EA3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Подсветка при наведении -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#505357"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка закрытия — при наведении становится красной -->
        <Style x:Key="WinCloseBtn" TargetType="Button"
               BasedOn="{StaticResource WinCtrlBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B03A2E"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ══════════ РАЗДЕЛИТЕЛЬ ПАНЕЛИ ИНСТРУМЕНТОВ ══════════ -->
        <Style x:Key="ToolSep" TargetType="Separator">
            <Setter Property="Width"      Value="1"/>
            <Setter Property="Height"     Value="18"/>
            <Setter Property="Margin"     Value="5,0"/>
            <Setter Property="Background" Value="#555760"/>
        </Style>

        <!-- ══════════ МЕТКА СТРОКИ СОСТОЯНИЯ ══════════ -->
        <Style x:Key="StatusLabel" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="Foreground"        Value="{StaticResource ColStatus}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ══════════ СТИЛЬ ПУНКТА КОНТЕКСТНОГО МЕНЮ ══════════ -->
        <Style TargetType="MenuItem">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding"  Value="6,4"/>
        </Style>

        <!-- ══════════ ТОНКИЙ СКРОЛЛБАР ДЛЯ ПАНЕЛИ ИНСТРУМЕНТОВ ══════════ -->
        <Style x:Key="ToolbarScrollBarThumb" TargetType="Thumb">
            <Setter Property="Background"       Value="#555760"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2" Margin="0,1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarScrollBar" TargetType="ScrollBar">
            <Setter Property="Height"      Value="4"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="False">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ToolbarScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarScroller" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Row="0"/>
                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Grid.Row="1"
                                       Orientation="Horizontal"
                                       Style="{StaticResource ToolbarScrollBar}"
                                       Value="{TemplateBinding HorizontalOffset}"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════════
         ВНЕШНЯЯ РАМКА ОКНА
         Скруглённые углы + тень — кастомный chrome без стандартного заголовка Windows
    ══════════════════════════════════════════════════════════ -->
    <Border Background="{StaticResource ColSurface}"
            CornerRadius="8"
            BorderBrush="{StaticResource ColBorder}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="3"
                              Opacity="0.22" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>   <!-- строка заголовка -->
                <RowDefinition Height="46"/>   <!-- панель инструментов -->
                <RowDefinition Height="*"/>    <!-- рабочий холст -->
                <RowDefinition Height="24"/>   <!-- строка состояния -->
            </Grid.RowDefinitions>

            <!-- ══════════ СТРОКА ЗАГОЛОВКА ══════════ -->
            <Border Grid.Row="0"
                    Background="{StaticResource ColTitleBg}"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="12,0,4,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Оранжевый акцентный штрих слева от названия -->
                        <Border Width="3" Height="16" CornerRadius="2"
                                Background="{StaticResource ColOrange}"
                                Margin="0,0,8,0"/>
                        <TextBlock Text="IDEF3"
                                   FontWeight="Bold" FontSize="13" FontFamily="Arial"
                                   Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text=" Editor"
                                   FontSize="13" FontFamily="Arial"
                                   Foreground="#9B9EA3" VerticalAlignment="Center"/>
                        <!-- Название текущей диаграммы (обновляется из кода) -->
                        <TextBlock x:Name="TitleDiagramName" Text=""
                                   FontSize="12"
                                   Foreground="{StaticResource ColOrangeLt}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                    <!-- Кнопки управления окном (свернуть / развернуть / закрыть) -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="MinimizeButton" Content="─"
                                Style="{StaticResource WinCtrlBtn}"
                                Click="MinimizeButton_Click"/>
                        <Button x:Name="MaximizeButton" Content="□"
                                Style="{StaticResource WinCtrlBtn}"
                                Click="MaximizeButton_Click"/>
                        <Button x:Name="CloseButton"    Content="✕"
                                Style="{StaticResource WinCloseBtn}"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════ ПАНЕЛЬ ИНСТРУМЕНТОВ ══════════ -->
            <Border Grid.Row="1"
                    Background="{StaticResource ColToolbarBg}"
                    BorderBrush="#25272A"
                    BorderThickness="0,0,0,1">
                <!-- ScrollViewer позволяет прокручивать кнопки на узких экранах -->
                <ScrollViewer Style="{StaticResource ToolbarScroller}"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0">

                    <!-- ГРУППА: Отмена / Повтор — тёмно-серый -->
                    <Button x:Name="UndoButton"  Content="Отмена"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColGrayDk}"
                            Width="68" Margin="0,0,2,0" IsEnabled="False"
                            ToolTip="Отменить (Ctrl+Z)"/>
                    <Button x:Name="RedoButton"  Content="Повтор"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColGrayDk}"
                            Width="64" Margin="0,0,0,0" IsEnabled="False"
                            ToolTip="Повторить (Ctrl+Y)"/>

                    <Separator Style="{StaticResource ToolSep}"/>

                    <!-- ГРУППА: Добавление элементов — оранжевый основной -->
                    <Button x:Name="AddUobButton"     Content="UOB"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColOrange}"
                            Width="44" Margin="0,0,2,0"
                            ToolTip="Добавить UOB-блок"/>
                    <Button x:Name="AddAndButton"     Content="J(&amp;)"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColOrangeDk}"
                            Width="44" Margin="0,0,2,0"
                            ToolTip="AND асинхронный"/>
                    <Button x:Name="AddAndSyncButton" Content="J(&amp;)s"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColOrangeDk}"
                            Width="50" Margin="0,0,2,0"
                            ToolTip="AND синхронный"/>
                    <Button x:Name="AddOrButton"      Content="J(O)"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColOrangeDk}"
                            Width="44" Margin="0,0,2,0"
                            ToolTip="OR асинхронный"/>
                    <Button x:Name="AddOrSyncButton"  Content="J(O)s"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColOrangeDk}"
                            Width="50" Margin="0,0,2,0"
                            ToolTip="OR синхронный"/>
                    <Button x:Name="AddXorButton"     Content="J(X)"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColOrangeDk}"
                            Width="44" Margin="0,0,0,0"
                            ToolTip="XOR"/>

                    <Separator Style="{StaticResource ToolSep}"/>

                    <!-- ГРУППА: Редактирование — оранжевая связь, тёмно-красное удаление -->
                    <Button x:Name="AddLinkButton" Content="Связь"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColOrangeLt}"
                            Width="56" Margin="0,0,2,0"
                            ToolTip="Режим добавления связи"/>
                    <Button x:Name="DeleteButton"  Content="Удалить"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColDanger}"
                            Width="66" Margin="0,0,0,0"
                            ToolTip="Удалить выбранный элемент (Del)"/>

                    <Separator Style="{StaticResource ToolSep}"/>

                    <!-- ГРУППА: Вид — средний серый -->
                    <Button x:Name="ToggleGridButton" Content="Сетка"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColGrayMid}"
                            MinWidth="82" Margin="0,0,2,0"
                            ToolTip="Показать / скрыть сетку"/>
                    <Button x:Name="ToggleSnapButton" Content="Привязка"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColGrayMid}"
                            MinWidth="88" Margin="0,0,4,0"
                            ToolTip="Привязка к сетке"/>

                    <!-- Кластер масштабирования -->
                    <Button x:Name="ZoomOutButton"   Content="-"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColGrayDk}"
                            Width="26" Margin="0,0,2,0"
                            ToolTip="Уменьшить (Ctrl+-)"/>
                    <TextBlock x:Name="ZoomLabel" Text="100%"
                               VerticalAlignment="Center" FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#9B9EA3"
                               Width="34" TextAlignment="Center"/>
                    <Button x:Name="ZoomInButton"    Content="+"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColGrayDk}"
                            Width="26" Margin="0,0,2,0"
                            ToolTip="Увеличить (Ctrl++)"/>
                    <Button x:Name="ZoomResetButton" Content="100%"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColGrayDk}"
                            Width="46" Margin="0,0,2,0"
                            ToolTip="Сбросить (Ctrl+0)"/>
                    <Button x:Name="HomeButton" Content="↖ Начало"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColGrayDk}"
                            Width="74" Margin="0,0,0,0"
                            ToolTip="Вернуться в начало холста (Ctrl+Home)"/>

                    <Separator Style="{StaticResource ToolSep}"/>

                    <!-- ГРУППА: Файл — тёмно-серый -->
                    <Button x:Name="SaveButton"    Content="Сохранить"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColGrayDk}"
                            Width="80" Margin="0,0,2,0"
                            ToolTip="Сохранить (Ctrl+S)"/>
                    <Button x:Name="LoadButton"    Content="Открыть"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColGrayDk}"
                            Width="66" Margin="0,0,2,0"
                            ToolTip="Открыть (Ctrl+O)"/>
                    <Button x:Name="RecentButton"  Content="Недавние"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColGrayDk}"
                            Width="74" Margin="0,0,2,0"
                            ToolTip="Последние файлы"
                            Click="RecentButton_Click"/>
                    <Button x:Name="ExportPngButton" Content="PNG"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColGrayMid}"
                            Width="44" Margin="0,0,2,0"
                            ToolTip="Экспортировать в PNG"/>
                    <Button x:Name="PropertiesButton" Content="Свойства"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColGrayMid}"
                            Width="76" Margin="0,0,0,0"
                            ToolTip="Свойства диаграммы"/>

                    <Separator Style="{StaticResource ToolSep}"/>

                    <!-- ГРУППА: Инструменты — оранжевые акценты -->
                    <Button x:Name="ValidateButton"  Content="Проверка"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColOrange}"
                            Width="74" Margin="0,0,2,0"
                            ToolTip="Проверить диаграмму (Ctrl+R)"/>
                    <Button x:Name="ReferenceButton" Content="Справка"
                            Style="{StaticResource ToolBtn}"
                            Background="{StaticResource ColGrayDk}"
                            Width="66"
                            ToolTip="Справочник IDEF3 (F1)"/>

                </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ══════════ ОБЛАСТЬ ХОЛСТА ══════════ -->
            <Border Grid.Row="2"
                    Margin="8,6,8,4"
                    Background="{StaticResource ColCanvas}"
                    CornerRadius="4"
                    BorderBrush="{StaticResource ColBorder}"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- хлебные крошки, скрыты на корневом уровне -->
                        <RowDefinition Height="*"/>   <!-- холст -->
                    </Grid.RowDefinitions>

                    <!-- Панель хлебных крошек: показывается только внутри декомпозиции -->
                    <Border x:Name="BreadcrumbPanel"
                            Grid.Row="0"
                            Visibility="Collapsed"
                            Background="#2B2D30"
                            Padding="8,5">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Кнопка «Назад» -->
                            <Button x:Name="BreadcrumbBackButton"
                                    Content="← Назад"
                                    Background="#505357" Foreground="White"
                                    BorderThickness="0" Padding="8,3"
                                    FontSize="11" FontWeight="SemiBold"
                                    Cursor="Hand" Margin="0,0,10,0"/>
                            <!-- Сами крошки добавляются из кода -->
                            <ItemsControl x:Name="BreadcrumbItems">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <ScrollViewer x:Name="CanvasScroll"
                                  Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  PanningMode="None">
                        <!-- Главный холст: масштаб и панорамирование через TransformGroup -->
                        <Canvas x:Name="CanvasHost"
                                Width="5000" Height="4000"
                                Background="Transparent">
                            <Canvas.RenderTransform>
                                <TransformGroup>
                                    <!-- Масштабирование (Ctrl + колесо мыши) -->
                                    <ScaleTransform     x:Name="CanvasScale" ScaleX="1" ScaleY="1"/>
                                    <!-- Панорамирование (ПКМ + перетаскивание) -->
                                    <TranslateTransform x:Name="CanvasPan"   X="0"      Y="0"/>
                                </TransformGroup>
                            </Canvas.RenderTransform>

                            <!-- Слой сетки — DrawingBrush тайловая кисть вместо сотен Line-объектов.
                                 Один раз создаётся, тайлится бесконечно, не пересоздаётся при ресайзе. -->
                            <Canvas x:Name="GridCanvas"
                                    Width="5000" Height="4000"
                                    IsHitTestVisible="False">
                                <Canvas.Background>
                                    <DrawingBrush TileMode="Tile"
                                                  Viewport="0,0,20,20"
                                                  ViewportUnits="Absolute"
                                                  Stretch="None">
                                        <DrawingBrush.Drawing>
                                            <GeometryDrawing>
                                                <GeometryDrawing.Pen>
                                                    <Pen Brush="#DCDCDC" Thickness="0.5"/>
                                                </GeometryDrawing.Pen>
                                                <GeometryDrawing.Geometry>
                                                    <PathGeometry>
                                                        <PathFigure StartPoint="20,0">
                                                            <LineSegment Point="20,20"/>
                                                        </PathFigure>
                                                        <PathFigure StartPoint="0,20">
                                                            <LineSegment Point="20,20"/>
                                                        </PathFigure>
                                                    </PathGeometry>
                                                </GeometryDrawing.Geometry>
                                            </GeometryDrawing>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </Canvas.Background>
                            </Canvas>

                            <!-- Рамка рабочей области — темнее сетки, всегда видна (не скрывается с сеткой) -->
                            <Rectangle Width="5000" Height="4000"
                                       Stroke="#A0A0A0" StrokeThickness="2"
                                       Fill="Transparent"
                                       IsHitTestVisible="False"/>

                            <!-- Слой рисования: блоки и связи диаграммы -->
                            <Canvas x:Name="DrawingCanvas"
                                    Width="5000" Height="4000"
                                    Background="Transparent"
                                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                                    MouseMove="Canvas_MouseMove"
                                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                                    MouseWheel="Canvas_MouseWheel"
                                    MouseRightButtonDown="Canvas_MouseRightButtonDown"
                                    MouseRightButtonUp="Canvas_MouseRightButtonUp"/>

                            <!-- Слой резиновой рамки группового выделения (поверх всего) -->
                            <Canvas x:Name="SelectionCanvas"
                                    Width="5000" Height="4000"
                                    Background="Transparent"
                                    IsHitTestVisible="False">
                                <Rectangle x:Name="RubberBandRect"
                                           Visibility="Collapsed"
                                           Stroke="#E8650A"
                                           StrokeThickness="1.5"
                                           StrokeDashArray="4 2"
                                           Fill="#18E8650A"
                                           RadiusX="2" RadiusY="2"/>
                            </Canvas>
                        </Canvas>
                    </ScrollViewer>

                    <!-- Информационный баннер режима (связь / размещение).
                         Отображается по центру вверху холста.
                         Текст и цвет управляются из кода в зависимости от режима. -->
                    <!-- Grid.Row="1" — поверх холста, не в строке хлебных крошек -->
                    <Border x:Name="LinkModeHint"
                            Grid.Row="1"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center" VerticalAlignment="Top"
                            Margin="0,10,0,0" Padding="16,5"
                            Background="{StaticResource ColOrange}"
                            CornerRadius="14">
                        <TextBlock x:Name="LinkModeHintText"
                                   Text="Режим связи: выберите источник"
                                   Foreground="White" FontSize="11"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <!-- Баннер панорамирования — появляется при зажатой ПКМ -->
                    <Border x:Name="PanHint"
                            Grid.Row="1"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center" VerticalAlignment="Top"
                            Margin="0,10,0,0" Padding="16,5"
                            Background="{StaticResource ColGrayDk}"
                            CornerRadius="14">
                        <TextBlock Text="Панорамирование — отпустите ПКМ"
                                   Foreground="White" FontSize="11"
                                   FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ══════════ СТРОКА СОСТОЯНИЯ ══════════ -->
            <Border Grid.Row="3"
                    Background="{StaticResource ColToolbarBg}"
                    BorderBrush="#25272A"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,8,8">
                <Grid Margin="12,0">
                    <!-- Левая часть: статус, счётчики блоков и связей, последнее действие -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText"
                                   Text="Готово"
                                   FontSize="11" Foreground="#9B9EA3"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="  ·  " FontSize="11" Foreground="#555760"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="NodeCountText"
                                   Text="Блоков: 0"
                                   FontSize="11" Foreground="#9B9EA3"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="  ·  " FontSize="11" Foreground="#555760"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="LinkCountText"
                                   Text="Связей: 0"
                                   FontSize="11" Foreground="#9B9EA3"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="  ·  " FontSize="11" Foreground="#555760"
                                   VerticalAlignment="Center"/>
                        <!-- Описание последнего действия для отмены (обновляется из кода) -->
                        <TextBlock x:Name="UndoStatusText"
                                   Text=""
                                   FontSize="11"
                                   Foreground="{StaticResource ColOrangeLt}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- Правая часть: краткая справка по горячим клавишам -->
                    <TextBlock Text="ПКМ — панорама/меню  ·  Ctrl+колесо — масштаб  ·  Del — удалить  ·  F1 — справка"
                               HorizontalAlignment="Right" VerticalAlignment="Center"
                               FontSize="10" Foreground="{StaticResource ColOrangeDk}"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
